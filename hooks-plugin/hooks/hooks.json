{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gated-runner.sh\" 'gh pr ' -- bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-pr-docs-check.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gated-runner.sh\" 'gh pr ' -- bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-pr-review-gate.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/block-force-push.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/guard-secret-reads.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/gated-runner.sh\" 'gh pr ' -- bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-pr-reflection.sh\""
          }
        ]
      }
    ]
  }
}
